<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AvaloniaBattleground.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="900"
        d:DesignHeight="620"
        x:Class="AvaloniaBattleground.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Avalonia Battleground"
        Width="900"
        Height="620"
        MinWidth="640"
        MinHeight="520">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid Margin="36" RowDefinitions="Auto,*" RowSpacing="32">
        <Grid ColumnDefinitions="*,Auto">
            <StackPanel Spacing="4">
                <TextBlock Text="Avalonia Battleground"
                           FontSize="32"
                           FontWeight="SemiBold"/>
                <TextBlock Text="{Binding CurrentScreenTitle}"
                           FontSize="16"
                           Opacity="0.72"/>
            </StackPanel>

            <Border Grid.Column="1"
                    BorderBrush="#55818A96"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="16,10"
                    VerticalAlignment="Center">
                <StackPanel Spacing="2">
                    <TextBlock Text="Local Display Name"
                               FontSize="12"
                               Opacity="0.72"/>
                    <TextBlock Text="{Binding CurrentDisplayName}"
                               FontSize="18"
                               FontWeight="SemiBold"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="1">
            <Grid IsVisible="{Binding IsMainMenu}">
                <StackPanel Width="360"
                            Spacing="16"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="Main Menu"
                               FontSize="24"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>

                    <StackPanel Spacing="8">
                        <TextBlock Text="Local Display Name"/>
                        <TextBox Text="{Binding DisplayNameInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 MinHeight="42"
                                 PlaceholderText="Player"/>
                        <Button Content="Save Name"
                                Command="{Binding SaveDisplayNameCommand}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"/>
                    </StackPanel>

                    <Button Content="Host Match"
                            Command="{Binding HostMatchCommand}"
                            MinHeight="42"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"/>
                    <Button Content="Join Match"
                            Command="{Binding JoinMatchCommand}"
                            MinHeight="42"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"/>
                    <Button Content="Exit"
                            Command="{Binding ExitCommand}"
                            MinHeight="42"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"/>
                </StackPanel>
            </Grid>

            <Grid IsVisible="{Binding IsPlaceholderScreen}">
                <StackPanel Width="360"
                            Spacing="16"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding CurrentScreenTitle}"
                               FontSize="24"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Not implemented yet."
                               HorizontalAlignment="Center"/>
                    <StackPanel Spacing="2"
                                HorizontalAlignment="Center">
                        <TextBlock Text="Local Display Name"
                                   FontSize="12"
                                   Opacity="0.72"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding CurrentDisplayName}"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                    <Button Content="Back"
                            Command="{Binding BackToMainMenuCommand}"
                            MinHeight="42"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
