<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AvaloniaBattleground.App.ViewModels"
        xmlns:views="using:AvaloniaBattleground.App.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="900"
        d:DesignHeight="620"
        x:Class="AvaloniaBattleground.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Avalonia Battleground"
        Width="900"
        Height="620"
        MinWidth="640"
        MinHeight="520">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid Margin="36" RowDefinitions="Auto,*" RowSpacing="32">
        <Grid ColumnDefinitions="*,Auto">
            <StackPanel Spacing="4">
                <TextBlock Text="Avalonia Battleground"
                           FontSize="32"
                           FontWeight="SemiBold"/>
                <TextBlock Text="{Binding CurrentScreenTitle}"
                           FontSize="16"
                           Opacity="0.72"/>
            </StackPanel>

            <Border Grid.Column="1"
                    BorderBrush="#55818A96"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="16,10"
                    VerticalAlignment="Center">
                <StackPanel Spacing="2">
                    <TextBlock Text="Local Display Name"
                               FontSize="12"
                               Opacity="0.72"/>
                    <TextBlock Text="{Binding CurrentDisplayName}"
                               FontSize="18"
                               FontWeight="SemiBold"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="1">
            <Grid IsVisible="{Binding CurrentScreen, Converter={x:Static views:EnumEqualsConverter.Instance}, ConverterParameter={x:Static vm:AppScreen.MainMenu}}">
                <StackPanel Width="360"
                            Spacing="16"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="Main Menu"
                               FontSize="24"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>

                    <StackPanel Spacing="8">
                        <TextBlock Text="Local Display Name"/>
                        <TextBox Text="{Binding DisplayNameInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 MinHeight="42"
                                 PlaceholderText="Player"/>
                        <Button Content="Save Name"
                                Command="{Binding SaveDisplayNameCommand}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Text="{Binding ConnectionFeedback}"
                               IsVisible="{Binding HasConnectionFeedback}"
                               Foreground="#B3261E"
                               TextWrapping="Wrap"/>

                    <Button Content="Host Match"
                            Command="{Binding HostMatchCommand}"
                            MinHeight="42"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"/>
                    <Button Content="Join Match"
                            Command="{Binding JoinMatchCommand}"
                            MinHeight="42"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"/>
                    <Button Content="Exit"
                            Command="{Binding ExitCommand}"
                            MinHeight="42"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"/>
                </StackPanel>
            </Grid>

            <Grid IsVisible="{Binding CurrentScreen, Converter={x:Static views:EnumEqualsConverter.Instance}, ConverterParameter={x:Static vm:AppScreen.Join}}">
                <StackPanel Width="420"
                            Spacing="16"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="Join Match"
                               FontSize="24"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>

                    <StackPanel Spacing="8">
                        <TextBlock Text="Host IP Address"/>
                        <TextBox Text="{Binding JoinAddressInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 MinHeight="42"
                                 PlaceholderText="127.0.0.1"/>
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Text="Port"/>
                        <TextBox Text="{Binding JoinPortInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 MinHeight="42"
                                 PlaceholderText="5000"/>
                    </StackPanel>

                    <TextBlock Text="{Binding ConnectionFeedback}"
                               IsVisible="{Binding HasConnectionFeedback}"
                               Foreground="#B3261E"
                               TextWrapping="Wrap"/>

                    <Button Content="Connect"
                            Command="{Binding JoinHostCommand}"
                            MinHeight="42"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"/>
                    <Button Content="Back"
                            Command="{Binding BackToMainMenuCommand}"
                            MinHeight="42"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"/>
                </StackPanel>
            </Grid>

            <Grid IsVisible="{Binding CurrentScreen, Converter={x:Static views:EnumEqualsConverter.Instance}, ConverterParameter={x:Static vm:AppScreen.Lobby}}">
                <StackPanel Width="520"
                            Spacing="18"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="Lobby"
                               FontSize="24"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>

                    <Border IsVisible="{Binding IsHostLobby}"
                            BorderBrush="#55818A96"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="16">
                        <Grid RowDefinitions="Auto,Auto"
                              ColumnDefinitions="Auto,*"
                              RowSpacing="8"
                              ColumnSpacing="16">
                            <TextBlock Text="Address"
                                       Opacity="0.72"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding HostAddressesDisplay}"
                                       TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="1"
                                       Text="Port"
                                       Opacity="0.72"/>
                            <TextBlock Grid.Row="1"
                                       Grid.Column="1"
                                       Text="{Binding HostPortDisplay}"/>
                        </Grid>
                    </Border>

                    <StackPanel Spacing="8">
                        <TextBlock Text="Connected Clients"
                                   FontWeight="SemiBold"/>
                        <ItemsControl ItemsSource="{Binding LobbyClients}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:LobbyClientItemViewModel">
                                    <Border BorderBrush="#33818A96"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="12"
                                            Margin="0,0,0,8">
                                        <Grid ColumnDefinitions="*,Auto"
                                              ColumnSpacing="12">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding DisplayName}"
                                                           FontSize="16"/>
                                                <StackPanel Orientation="Horizontal"
                                                            Spacing="12">
                                                    <TextBlock Text="{Binding TeamDisplay}"
                                                               Opacity="0.72"/>
                                                    <TextBlock Text="{Binding RoleDisplay}"
                                                               Opacity="0.72"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding HostMarker}"
                                                       IsVisible="{Binding IsHost}"
                                                       Opacity="0.72"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <Grid ColumnDefinitions="*,*"
                          RowDefinitions="Auto,Auto"
                          ColumnSpacing="12"
                          RowSpacing="8">
                        <TextBlock Text="Team"/>
                        <TextBlock Grid.Column="1"
                                   Text="Fighter Role"/>
                        <ComboBox Grid.Row="1"
                                  ItemsSource="{Binding TeamOptions}"
                                  SelectedItem="{Binding SelectedTeam, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch"/>
                        <ComboBox Grid.Row="1"
                                  Grid.Column="1"
                                  ItemsSource="{Binding RoleOptions}"
                                  SelectedItem="{Binding SelectedRole, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch"/>
                    </Grid>

                    <TextBlock Text="{Binding SelectionFeedback}"
                               IsVisible="{Binding HasSelectionFeedback}"
                               Foreground="#B3261E"
                               TextWrapping="Wrap"/>

                    <Button Content="Apply Selection"
                            Command="{Binding ApplySelectionCommand}"
                            MinHeight="42"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"/>

                    <StackPanel IsVisible="{Binding IsHostLobby}"
                                Spacing="8">
                        <TextBlock Text="{Binding StartLockStatus}"
                                   Opacity="0.72"
                                   TextWrapping="Wrap"/>
                        <Button Content="Start Match"
                                Command="{Binding StartMatchCommand}"
                                IsEnabled="{Binding CanStartMatch}"
                                MinHeight="42"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"/>
                    </StackPanel>

                    <Button Content="Back"
                            Command="{Binding BackToMainMenuCommand}"
                            MinHeight="42"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"/>
                </StackPanel>
            </Grid>

            <Grid IsVisible="{Binding CurrentScreen, Converter={x:Static views:EnumEqualsConverter.Instance}, ConverterParameter={x:Static vm:AppScreen.Match}}"
                  RowDefinitions="Auto,*,Auto,Auto"
                  RowSpacing="12">
                <Grid ColumnDefinitions="*,Auto,*"
                      ColumnSpacing="16">
                    <StackPanel Orientation="Horizontal"
                                Spacing="12"
                                VerticalAlignment="Center">
                        <TextBlock Text="{Binding MatchRoundDisplay}"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding MatchTimerDisplay}"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               Text="{Binding MatchScoreDisplay}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>

                    <TextBlock Grid.Column="2"
                               Text="{Binding MatchResultDisplay}"
                               IsVisible="{Binding HasMatchResult}"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               Opacity="0.78"/>
                </Grid>

                <Grid Grid.Row="1">
                    <views:GameSurface MatchSnapshot="{Binding MatchSnapshot}"
                                       MinHeight="320"
                                       HorizontalAlignment="Stretch"
                                       VerticalAlignment="Stretch"
                                       Focusable="True"/>

                    <Border IsVisible="{Binding HasMatchResult}"
                            Background="#DD101418"
                            BorderBrush="#66F4F7FA"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="24,18"
                            MaxWidth="420"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <StackPanel Spacing="6">
                            <TextBlock Text="{Binding MatchResultDisplay}"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding MatchScoreDisplay}"
                                       FontSize="16"
                                       TextAlignment="Center"
                                       Opacity="0.78"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <ItemsControl Grid.Row="2"
                              ItemsSource="{Binding MatchFighters}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="1"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:MatchFighterHudItemViewModel">
                            <Border BorderBrush="#33818A96"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="10"
                                    Margin="0,0,8,0">
                                <Grid RowDefinitions="Auto,Auto,Auto"
                                      RowSpacing="6">
                                    <Grid ColumnDefinitions="*,Auto"
                                          ColumnSpacing="8">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding StateDisplay}"
                                                   Opacity="0.72"/>
                                    </Grid>

                                    <StackPanel Grid.Row="1"
                                                Orientation="Horizontal"
                                                Spacing="8">
                                        <TextBlock Text="{Binding TeamDisplay}"
                                                   Opacity="0.72"/>
                                        <TextBlock Text="{Binding RoleDisplay}"
                                                   Opacity="0.72"/>
                                    </StackPanel>

                                    <Grid Grid.Row="2"
                                          RowDefinitions="Auto,Auto,Auto"
                                          ColumnDefinitions="Auto,*"
                                          RowSpacing="3"
                                          ColumnSpacing="8">
                                        <TextBlock Text="Health"
                                                   Opacity="0.72"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding HealthDisplay}"
                                                   HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Row="1"
                                                   Text="Primary"
                                                   Opacity="0.72"/>
                                        <TextBlock Grid.Row="1"
                                                   Grid.Column="1"
                                                   Text="{Binding PrimaryCooldownDisplay}"
                                                   HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Row="2"
                                                   Text="Ability"
                                                   Opacity="0.72"/>
                                        <TextBlock Grid.Row="2"
                                                   Grid.Column="1"
                                                   Text="{Binding AbilityCooldownDisplay}"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Button Grid.Row="3"
                        Content="Back"
                        Command="{Binding BackToMainMenuCommand}"
                        MinHeight="42"
                        Width="180"
                        HorizontalAlignment="Center"
                        HorizontalContentAlignment="Center"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
