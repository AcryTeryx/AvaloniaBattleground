<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AvaloniaBattleground.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="900"
        d:DesignHeight="620"
        x:Class="AvaloniaBattleground.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Avalonia Battleground"
        Width="900"
        Height="620"
        MinWidth="640"
        MinHeight="520">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid Margin="36" RowDefinitions="Auto,*" RowSpacing="32">
        <Grid ColumnDefinitions="*,Auto">
            <StackPanel Spacing="4">
                <TextBlock Text="Avalonia Battleground"
                           FontSize="32"
                           FontWeight="SemiBold"/>
                <TextBlock Text="{Binding CurrentScreenTitle}"
                           FontSize="16"
                           Opacity="0.72"/>
            </StackPanel>

            <Border Grid.Column="1"
                    BorderBrush="#55818A96"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="16,10"
                    VerticalAlignment="Center">
                <StackPanel Spacing="2">
                    <TextBlock Text="Local Display Name"
                               FontSize="12"
                               Opacity="0.72"/>
                    <TextBlock Text="{Binding CurrentDisplayName}"
                               FontSize="18"
                               FontWeight="SemiBold"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="1">
            <Grid IsVisible="{Binding IsMainMenu}">
                <StackPanel Width="360"
                            Spacing="16"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="Main Menu"
                               FontSize="24"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>

                    <StackPanel Spacing="8">
                        <TextBlock Text="Local Display Name"/>
                        <TextBox Text="{Binding DisplayNameInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 MinHeight="42"
                                 PlaceholderText="Player"/>
                        <Button Content="Save Name"
                                Command="{Binding SaveDisplayNameCommand}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Text="{Binding ConnectionFeedback}"
                               IsVisible="{Binding HasConnectionFeedback}"
                               Foreground="#B3261E"
                               TextWrapping="Wrap"/>

                    <Button Content="Host Match"
                            Command="{Binding HostMatchCommand}"
                            MinHeight="42"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"/>
                    <Button Content="Join Match"
                            Command="{Binding JoinMatchCommand}"
                            MinHeight="42"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"/>
                    <Button Content="Exit"
                            Command="{Binding ExitCommand}"
                            MinHeight="42"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"/>
                </StackPanel>
            </Grid>

            <Grid IsVisible="{Binding IsJoinScreen}">
                <StackPanel Width="420"
                            Spacing="16"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="Join Match"
                               FontSize="24"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>

                    <StackPanel Spacing="8">
                        <TextBlock Text="Host IP Address"/>
                        <TextBox Text="{Binding JoinAddressInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 MinHeight="42"
                                 PlaceholderText="127.0.0.1"/>
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Text="Port"/>
                        <TextBox Text="{Binding JoinPortInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 MinHeight="42"
                                 PlaceholderText="5000"/>
                    </StackPanel>

                    <TextBlock Text="{Binding ConnectionFeedback}"
                               IsVisible="{Binding HasConnectionFeedback}"
                               Foreground="#B3261E"
                               TextWrapping="Wrap"/>

                    <Button Content="Connect"
                            Command="{Binding JoinHostCommand}"
                            MinHeight="42"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"/>
                    <Button Content="Back"
                            Command="{Binding BackToMainMenuCommand}"
                            MinHeight="42"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"/>
                </StackPanel>
            </Grid>

            <Grid IsVisible="{Binding IsLobbyScreen}">
                <StackPanel Width="520"
                            Spacing="18"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="Lobby"
                               FontSize="24"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>

                    <Border IsVisible="{Binding IsHostLobby}"
                            BorderBrush="#55818A96"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="16">
                        <Grid RowDefinitions="Auto,Auto"
                              ColumnDefinitions="Auto,*"
                              RowSpacing="8"
                              ColumnSpacing="16">
                            <TextBlock Text="Address"
                                       Opacity="0.72"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding HostAddressesDisplay}"
                                       TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="1"
                                       Text="Port"
                                       Opacity="0.72"/>
                            <TextBlock Grid.Row="1"
                                       Grid.Column="1"
                                       Text="{Binding HostPortDisplay}"/>
                        </Grid>
                    </Border>

                    <StackPanel Spacing="8">
                        <TextBlock Text="Connected Clients"
                                   FontWeight="SemiBold"/>
                        <ItemsControl ItemsSource="{Binding LobbyClients}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:LobbyClientItemViewModel">
                                    <Border BorderBrush="#33818A96"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="12"
                                            Margin="0,0,0,8">
                                        <Grid ColumnDefinitions="*,Auto"
                                              ColumnSpacing="12">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding DisplayName}"
                                                           FontSize="16"/>
                                                <StackPanel Orientation="Horizontal"
                                                            Spacing="12">
                                                    <TextBlock Text="{Binding TeamDisplay}"
                                                               Opacity="0.72"/>
                                                    <TextBlock Text="{Binding RoleDisplay}"
                                                               Opacity="0.72"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding HostMarker}"
                                                       IsVisible="{Binding IsHost}"
                                                       Opacity="0.72"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <Grid ColumnDefinitions="*,*"
                          RowDefinitions="Auto,Auto"
                          ColumnSpacing="12"
                          RowSpacing="8">
                        <TextBlock Text="Team"/>
                        <TextBlock Grid.Column="1"
                                   Text="Fighter Role"/>
                        <ComboBox Grid.Row="1"
                                  ItemsSource="{Binding TeamOptions}"
                                  SelectedItem="{Binding SelectedTeam, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch"/>
                        <ComboBox Grid.Row="1"
                                  Grid.Column="1"
                                  ItemsSource="{Binding RoleOptions}"
                                  SelectedItem="{Binding SelectedRole, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch"/>
                    </Grid>

                    <TextBlock Text="{Binding SelectionFeedback}"
                               IsVisible="{Binding HasSelectionFeedback}"
                               Foreground="#B3261E"
                               TextWrapping="Wrap"/>

                    <Button Content="Apply Selection"
                            Command="{Binding ApplySelectionCommand}"
                            MinHeight="42"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"/>

                    <StackPanel IsVisible="{Binding IsHostLobby}"
                                Spacing="8">
                        <TextBlock Text="{Binding StartLockStatus}"
                                   Opacity="0.72"
                                   TextWrapping="Wrap"/>
                        <Button Content="Start Match"
                                Command="{Binding StartMatchCommand}"
                                IsEnabled="{Binding CanStartMatch}"
                                MinHeight="42"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"/>
                    </StackPanel>

                    <Button Content="Back"
                            Command="{Binding BackToMainMenuCommand}"
                            MinHeight="42"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
